<% layout("layouts/boilerplate") %>

    <body>
        <main class="container">
            <div class="row">
                <div class="col-12">
                    <a href="/listings" class="mt-3 mb-3 ms-3 show-left-arrow btn border border-0"><i
                            class="fa-solid left-arrow fa-arrow-left-long me-2">&nbsp;&nbsp;</i>Back to
                        Listings</a>
                    <div class="card show-card">
                        <img src="<%= listDetail.image.url %>" class="card-img-top mb-4 rounded-4 show-img"
                            alt="<%= listDetail.title %>">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="mt-4 col-12 col-lg-7">
                    <div class="row">
                        <div class="col-12">
                            <div class="card-body">
                                <div class="d-flex flex-wrap location fs-small jc-between">
                                    <div class="d-flex ai-center text-start">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                            viewBox="0 0 24 24" style="color: #c9a96e;" fill="none"
                                            stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="lucide fw-lighter lucide-map-pin w-4 h-4 mr-1">
                                            <path
                                                d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0">
                                            </path>
                                            <circle cx="12" cy="10" r="3"></circle>
                                        </svg>
                                        <p class="card-text fw-bolder fs-6" style="color: gray;">
                                            <%= listDetail.location %>, <%= listDetail.country %>
                                        </p>
                                    </div>
                                    <% if(currentUser && currentUser._id.equals(listDetail.owner._id)) { %>
                                        <div class="d-flex bg-secondary bg-opacity-10 p-1 rounded-4">
                                            <a class="ed-btn" href="/listings/<%= listDetail.id %>/edit"><i
                                                    class="fa-regular edit-btn fa-pen-to-square bg-white rounded-4 me-1 d-flex ai-cneter jc-center"></i></a>
                                            <form class="d-flex ai-start d-btn" method="post"
                                                action="/listings/<%= listDetail.id %>/?_method=DELETE"
                                                id="delete-listing" data-title="<%= listDetail.title %>"><br>
                                                <button class="border border-0"><i
                                                        class="fa-regular del-btn fa-trash-can bg-white rounded-4 d-flex ai-cneter jc-center"></i></button>
                                            </form>
                                        </div>
                                        <% } %>
                                </div>
                                <p id="heading" class="text-start fs-1 fw-lighter">
                                    <%= listDetail.title %><br>
                                </p>
                                <p class="card-text show-text fs-5 fw-xl">
                                    <%= listDetail.description %>
                                </p>
                            </div>
                        </div>
                        <div class="col-12">
                            <%# if(currentUser) {%>
                                <hr class="my-5">
                                <div class="d-flex jc-between">
                                    <% if(listDetail.reviews.length> 0) {%>
                                        <h3 class="mb-3">Guest Experiences</h3><br>
                                        <a class="btn add-review-btn c-gold form-btn d-none d-sm-block add-review"
                                            data-listing="<%= listDetail.id %>"><i class="fa-solid fa-plus"
                                                style="color: #c9a96e;"></i>
                                            Add review</a>
                                        <% } %>
                                            <% if(listDetail.reviews.length===0) { %>
                                                <div class="col-12">
                                                    <a class="btn add-review-btn c-gold no-add-review d-none d-lg-block py-3 px-5 mb-2 rounded-4 add-review"
                                                        data-listing="<%= listDetail.id %>"><i class="fa-solid fa-plus"
                                                            style="color: gray ;"></i> Add
                                                        review</a>
                                                </div>
                                                <% } %>
                                </div>
                                <%# } %>
                                    <% if(listDetail.reviews.length> 0) {%>
                                        <% for( let review of listDetail.reviews ) { %>
                                            <div class="review-card ms-auto my-3 col-12"
                                                style="background-color: #f5f5f5; border: none;">
                                                <div class="d-flex jc-between">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40"
                                                        viewBox="0 0 24 24" fill="none" stroke="rgba(0,0,0,0.2)"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                        class="lucide lucide-quote text-gray-200 w-10 h-10 mb-4">
                                                        <path
                                                            d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z">
                                                        </path>
                                                        <path
                                                            d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z">
                                                        </path>
                                                    </svg>
                                                    <p class=" starability-result" data-rating="<%= review.rating %>">
                                                        Rated: 3 stars
                                                    </p>
                                                </div>
                                                <div class="infos">
                                                    <p class="date-time">
                                                        <%= review.__v> 0 ? "Updated " +
                                                            timeAgo(review.createdAt) :
                                                            timeAgo(review.createdAt)
                                                            %>
                                                    </p>
                                                    <p class="description fst-italic">
                                                        <%= review.comment %>
                                                    </p>
                                                </div>
                                                <div
                                                    class="author fs-s d-flex ai-center jc-between w-100 position-relative bottom-0">
                                                    &horbar; <%= review.author.username %>
                                                        <% if(currentUser && currentUser._id.equals(review.author._id))
                                                            { %>
                                                            <div class="d-flex jc-between">
                                                                <div>

                                                                    <a class="btn review-btn fs-s"
                                                                        style="color : rgba(107, 114, 128, 1);"
                                                                        href="/listings/<%= listDetail.id %>/reviews/<%= review.id %>/edit"><i
                                                                            class="fa-regular fa-pen-to-square"></i>
                                                                        Edit</a>
                                                                </div>
                                                                <form
                                                                    action="/listings/<%= listDetail.id %>/reviews/<%= review.id %>/?_method=DELETE"
                                                                    method="post" class="d-flex ai-center">

                                                                    <button class="btn review-btn fs-s p-0"
                                                                        type="submit"
                                                                        style="color : rgba(107, 114, 128, 1);"><i
                                                                            class="fa-regular fa-trash-can"></i>
                                                                        Delete</button>
                                                                </form>
                                                            </div>
                                                            <% } %>
                                                </div>

                                            </div>
                                            <% } %>
                                                <% } %>
                        </div>
                    </div>

                </div>
                <div class="col-12 col-sm-12 col-lg-4 offset-lg-1 mb-3 mt-4">
                    <div class="bg-white position-sticky reserve-card review-card">
                        <div class=" rounded-4">
                            <span class="fs-2 fw-xl">&#8377;<%= listDetail.price.toLocaleString("en-IN") %>
                            </span>/ night
                            <div class="d-flex flex-column ai-center mt-4">
                                <button class="rev-btn py-3 rounded-3 fw-bolder bg-col">Reserve Now</button> <br>
                                <small class="fs-s">You won't be charged yet</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <a class="btn add-review-btn c-gold d-lg-none no-add-review d-block py-3 px-5 mb-2 rounded-4 add-review"
                        data-listing="<%= listDetail.id %>"><i class="fa-solid fa-plus" style="color: gray ;"></i> Add
                        review</a>
                </div>
            </div>
        </main>
    </body>