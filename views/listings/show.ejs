<% layout("layouts/boilerplate") %>

    <body>
        <br>
        <h1 id="heading"><b>
                <%= listDetail.title %>
            </b><br></h1>
        <div class="row mt-3">
            <div class="col-8 offset-2">
                <h4 class="mt-3 mb-3 ms-3">Owned By: <i>&nbsp;<%= listDetail.owner.username %></i></h4>
                <div class="card listing-card">
                    <img src="<%= listDetail.image.url %>" class="card-img-top mb-4 show-img" alt="<%= listDetail.title %>">
                    <div class="card-body">
                        <p class="card-text show-text">
                            <%= listDetail.description %>
                        </p>
                        <p class="card-text show-text">
                            &#8377;<%= listDetail.price.toLocaleString("en-IN") %>/night </p>
                        <p class="card-text show-text">
                            <%= listDetail.location %>
                        </p>
                        <p class="card-text show-text">
                            <%= listDetail.country %>
                        </p>
                    </div>
                    <% if(currentUser && currentUser._id.equals(listDetail.owner._id)) { %>
                        <div class="d-flex mt-3">
                            <a class="btn btn-dark form-btn col-sm-6 col-md-2"
                                href="/listings/<%= listDetail.id %>/edit">Edit</a>
                            <form class="d-flex ai-start" method="post"
                                action="/listings/<%= listDetail.id %>/?_method=DELETE"><br>
                                <button class="btn btn-dark form-btn">Delete</button>
                            </form>
                        </div>
                        <% } %>
                </div>
            </div>
        </div>
        <div class="row mb-4">
            <div class="col-8 offset-2">
                <% if(currentUser) { %>
                    <hr>
                    <h4>Leave a Review</h4>
                    <form method="post" action="/listings/<%= listDetail.id %>/reviews" novalidate
                        class="needs-validation">
                        <!-- <div class="mb-3">
                            <label for="rating" class="form-label">Rating</label>
                            <input class="form-range" type="range" name="rating" id="rating" min="1" max="5">
                        </div> -->
                        <div class="mb-3">
                            <label for="rating" class="form-label">Rating</label>
                            <fieldset class="starability-slot">
                                <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked
                                    aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="rating" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="rating" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="rating" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="rating" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="rating" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>
                        </div>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Comment</label>
                            <textarea class="form-control" name="comment" id="comment" rows="2" required></textarea>
                            <div class="invalid-feedback">*Cannot Submit Empty</div>
                        </div>
                        <button class="btn btn-dark form-btn">Add review</button>
                    </form>
                    <% } %>
            </div>
        </div>
        <div class="row mb-4">
            <!-- <div class="col-8 offset-2">
                <h3>Where you'll be</h3>
                <div id="map"></div>
            </div> -->
            <div class="col-8 offset-2">
                <% if(listDetail.reviews.length> 0) {%>
                    <hr>
                    <h3>All Reviews</h3><br>
                    <% } %>
                        <div class="row d-flex justify-content-between">
                            <% for( let review of listDetail.reviews ) { %>
                                <div class="card col-5 ms-2 mb-3 review-card">
                                    <div class="card-body">
                                        <h4 class="card-title mt-3">@<%= review.author.username %>
                                        </h4>
                                        <hr>
                                        <p class="card-text mb-3 starability-result" data-rating="<%= review.rating %>">
                                            Rated: 3 stars
                                        </p>
                                        <p class="card-text mb-2">
                                            <%= review.comment %>
                                        </p>
                                    </div>
                                    <% if(currentUser && currentUser._id.equals(review.author._id)) { %>
                                        <form
                                            action="/listings/<%= listDetail.id %>/reviews/<%= review.id %>/?_method=DELETE"
                                            method="post" class="mb-3">
                                            <button class="btn btn-dark">Delete</button>
                                        </form>
                                        <% } %>
                                </div>
                                <% } %>
                        </div>
            </div>
        </div>
