<% layout("layouts/boilerplate") %>

<style>
    /* Custom Styling for Sticker-Themed Error Page */
    .error-page-container {
        position: relative;
        background-color: #faf8f5;
        /* Cozy notebook grid background */
        background-image: 
            linear-gradient(rgba(201, 169, 110, 0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(201, 169, 110, 0.08) 1px, transparent 1px);
        background-size: 24px 24px;
        min-height: 80vh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4rem 1.5rem;
        overflow: hidden;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* Subtly animated background elements */
    .error-bg-circle {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(201, 169, 110, 0.12) 0%, transparent 70%);
        z-index: 1;
    }
    .circle-1 { width: 400px; height: 400px; top: -100px; left: -100px; }
    .circle-2 { width: 500px; height: 500px; bottom: -150px; right: -100px; }

    /* Glassmorphism Card containing details */
    .error-card {
        position: relative;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 28px;
        padding: 3rem 2rem;
        box-shadow: 
            0 10px 30px -10px rgba(11, 29, 38, 0.05),
            0 25px 50px -12px rgba(11, 29, 38, 0.1);
        text-align: center;
        max-width: 580px;
        width: 100%;
        z-index: 5;
        transition: transform 0.3s ease;
    }

    /* Main Sticker Wrapper */
    .sticker-wrapper {
        position: relative;
        width: 220px;
        height: 220px;
        margin: 0 auto 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* The White Border and Shadow Sticker Effect */
    .sticker-main {
        width: 100%;
        height: 100%;
        cursor: grab;
        filter: 
            drop-shadow(0 -4px 0 #ffffff) 
            drop-shadow(4px 0 0 #ffffff) 
            drop-shadow(0 4px 0 #ffffff) 
            drop-shadow(-4px 0 0 #ffffff) 
            drop-shadow(0 6px 0 rgba(201, 169, 110, 0.3))
            drop-shadow(0 12px 16px rgba(11, 29, 38, 0.15));
        animation: floatMain 4s ease-in-out infinite;
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .sticker-main:hover {
        transform: scale(1.08) rotate(3deg);
    }
    .sticker-main:active {
        cursor: grabbing;
        transform: scale(0.98) rotate(-2deg);
    }

    /* Decorative Laptop Stickers */
    .deco-sticker {
        position: absolute;
        z-index: 6;
        cursor: pointer;
        filter: 
            drop-shadow(0 -3px 0 #ffffff) 
            drop-shadow(3px 0 0 #ffffff) 
            drop-shadow(0 3px 0 #ffffff) 
            drop-shadow(-3px 0 0 #ffffff) 
            drop-shadow(0 4px 6px rgba(11, 29, 38, 0.12));
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .deco-sticker:hover {
        transform: scale(1.15) rotate(-5deg);
    }

    .sticker-pin {
        width: 60px;
        height: 60px;
        top: -20px;
        left: -20px;
        animation: floatDeco1 5s ease-in-out infinite;
    }

    .sticker-cozy {
        width: 75px;
        height: 75px;
        bottom: -25px;
        right: -25px;
        animation: floatDeco2 6s ease-in-out infinite;
    }

    .sticker-star {
        width: 45px;
        height: 45px;
        bottom: 40px;
        left: -30px;
        animation: floatDeco3 4.5s ease-in-out infinite;
    }

    /* Typography styles */
    .error-code-badge {
        display: inline-block;
        background-color: rgba(201, 169, 110, 0.15);
        color: #C9A96E;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        padding: 0.4rem 1.2rem;
        border-radius: 50px;
        margin-bottom: 1rem;
    }

    .error-title {
        color: #0B1D26;
        font-weight: 700;
        font-size: 1.85rem;
        margin-bottom: 0.8rem;
    }

    .error-desc {
        color: #6c757d;
        font-weight: 400;
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 2rem;
        padding: 0 1rem;
    }

    /* Action Buttons */
    .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-staynest-primary {
        background-color: #0B1D26;
        color: #ffffff;
        font-weight: 600;
        padding: 0.75rem 1.8rem;
        border-radius: 12px;
        border: none;
        transition: all 0.25s ease;
        box-shadow: 0 4px 12px rgba(11, 29, 38, 0.15);
        text-decoration: none;
    }
    .btn-staynest-primary:hover {
        background-color: #C9A96E;
        color: #ffffff;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(201, 169, 110, 0.3);
    }

    .btn-staynest-secondary {
        background-color: transparent;
        color: #0B1D26;
        font-weight: 600;
        padding: 0.75rem 1.8rem;
        border-radius: 12px;
        border: 2px solid #e5e0d8;
        transition: all 0.25s ease;
        text-decoration: none;
    }
    .btn-staynest-secondary:hover {
        background-color: rgba(11, 29, 38, 0.03);
        border-color: #0B1D26;
        transform: translateY(-2px);
    }

    /* SVG Animation Keyframes */
    @keyframes floatMain {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-8px) rotate(1.5deg); }
    }
    @keyframes floatDeco1 {
        0%, 100% { transform: translateY(0) rotate(-10deg); }
        50% { transform: translateY(-5px) rotate(-6deg); }
    }
    @keyframes floatDeco2 {
        0%, 100% { transform: translateY(0) rotate(15deg); }
        50% { transform: translateY(-6px) rotate(10deg); }
    }
    @keyframes floatDeco3 {
        0%, 100% { transform: translateY(0) rotate(-5deg); }
        50% { transform: translateY(-4px) rotate(5deg); }
    }

    /* Cloud bobbing animation in SVG */
    .svg-cloud {
        animation: svgCloudMove 6s ease-in-out infinite alternate;
    }
    @keyframes svgCloudMove {
        from { transform: translateX(-4px); }
        to { transform: translateX(4px); }
    }

    /* Rain drip animation in SVG */
    .svg-rain {
        animation: svgRainFall 1.5s linear infinite;
    }
    .rain-delay-1 { animation-delay: 0.3s; }
    .rain-delay-2 { animation-delay: 0.7s; }
    @keyframes svgRainFall {
        0% { transform: translateY(-5px); opacity: 0; }
        30% { opacity: 0.8; }
        100% { transform: translateY(15px); opacity: 0; }
    }

    /* Lightning flicker */
    .svg-lightning {
        animation: svgFlicker 3s infinite;
    }
    @keyframes svgFlicker {
        0%, 90%, 100% { opacity: 0.3; }
        93%, 97% { opacity: 1; }
    }
</style>

<%
    // Ensure status and message are defined, with friendly defaults
    const errStatus = (typeof status !== 'undefined') ? status : 404;
    const errMsg = (typeof message !== 'undefined') ? message : 'The page you are looking for does not exist or has been moved.';
    
    // Choose appropriate heading titles based on status code
    let errorHeading = "Cozy Nest Not Found";
    if (errStatus >= 500) {
        errorHeading = "Storm in the Nest!";
    } else if (errStatus === 403) {
        errorHeading = "Restricted Area";
    }
%>

<div class="error-page-container">
    <div class="error-bg-circle circle-1"></div>
    <div class="error-bg-circle circle-2"></div>

    <div class="error-card">
        
        <!-- Decorative Sticker 1: Location Pin (Smiley) -->
        <div class="deco-sticker sticker-pin" title="StayNest Location">
            <svg viewBox="0 0 100 100" width="100%" height="100%">
                <circle cx="50" cy="50" r="45" fill="#4ea8de" />
                <path d="M50,15 C33,15 20,28 20,45 C20,68 50,85 50,85 C50,85 80,68 80,45 C80,28 67,15 50,15 Z" fill="#ff70a6" />
                <circle cx="50" cy="42" r="14" fill="#ffffff" />
                <!-- Happy eyes and mouth -->
                <circle cx="45" cy="40" r="2.5" fill="#ff70a6" />
                <circle cx="55" cy="40" r="2.5" fill="#ff70a6" />
                <path d="M45,46 Q50,50 55,46" stroke="#ff70a6" stroke-width="2.5" stroke-linecap="round" fill="none" />
            </svg>
        </div>

        <!-- Decorative Sticker 2: Cozy Star -->
        <div class="deco-sticker sticker-star" title="Cozy Stay">
            <svg viewBox="0 0 100 100" width="100%" height="100%">
                <polygon points="50,5 64,36 98,36 70,57 81,91 50,70 19,91 30,57 2,36 36,36" fill="#ffd166" />
                <!-- Cute face -->
                <circle cx="42" cy="48" r="3.5" fill="#0B1D26" />
                <circle cx="58" cy="48" r="3.5" fill="#0B1D26" />
                <path d="M46,56 Q50,60 54,56" stroke="#0B1D26" stroke-width="3" stroke-linecap="round" fill="none" />
            </svg>
        </div>

        <!-- Decorative Sticker 3: Cozy Vibes Badge -->
        <div class="deco-sticker sticker-cozy" title="Cozy Vibes Only">
            <svg viewBox="0 0 100 100" width="100%" height="100%">
                <circle cx="50" cy="50" r="45" fill="#0B1D26" />
                <circle cx="50" cy="50" r="40" fill="none" stroke="#C9A96E" stroke-width="2.5" stroke-dasharray="6,4" />
                <path d="M30,48 Q50,30 70,48" stroke="#ffffff" stroke-width="4" stroke-linecap="round" fill="none" />
                <path d="M34,42 L34,58 M66,42 L66,58" stroke="#C9A96E" stroke-width="3" stroke-linecap="round" />
                <text x="50" y="70" fill="#ffffff" font-size="9" font-family="'Plus Jakarta Sans', sans-serif" font-weight="700" text-anchor="middle" letter-spacing="1">STAY COZY</text>
            </svg>
        </div>

        <!-- Main Dynamic Sticker -->
        <div class="sticker-wrapper">
            <% if (errStatus === 404) { %>
                <!-- 404 Sticker: Cute Empty Nest with Floating Question Mark and Lost Bird Flying Away -->
                <svg class="sticker-main" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                    <!-- Soft sky background circle -->
                    <circle cx="100" cy="100" r="85" fill="#e8f1f5" />
                    
                    <!-- Floating clouds (animated via CSS class) -->
                    <g class="svg-cloud">
                        <path d="M40,75 C35,75 30,70 30,65 C30,60 35,55 42,55 C45,45 55,42 60,48 C65,48 70,52 70,58 C70,65 65,75 40,75 Z" fill="#ffffff" opacity="0.9" />
                        <path d="M140,55 C135,55 132,52 130,48 C128,40 138,35 145,38 C148,32 158,32 162,38 C168,38 172,44 170,50 C170,53 165,55 140,55 Z" fill="#ffffff" opacity="0.8" />
                    </g>
                    
                    <!-- Branches/Tree Trunk -->
                    <path d="M30,150 Q100,165 170,140 M100,157 L100,180" stroke="#8d6e63" stroke-width="8" stroke-linecap="round" fill="none" />
                    
                    <!-- Cute Empty Nest Structure -->
                    <!-- Outer twigs (back) -->
                    <ellipse cx="100" cy="140" rx="60" ry="25" fill="#a1887f" />
                    
                    <!-- Inside lining (dark shadow) -->
                    <ellipse cx="100" cy="135" rx="45" ry="18" fill="#5d4037" />
                    
                    <!-- Cute sleeping grass / straws -->
                    <path d="M60,135 Q80,145 110,130 M70,142 Q100,152 130,138 M90,132 Q115,148 140,132" stroke="#ffe082" stroke-width="3" stroke-linecap="round" fill="none" />
                    
                    <!-- Wooden Sign Post inside nest -->
                    <g>
                        <rect x="96" y="90" width="8" height="35" fill="#8d6e63" rx="2" />
                        <rect x="75" y="70" width="50" height="25" fill="#d7ccc8" rx="4" stroke="#8d6e63" stroke-width="2.5" />
                        <!-- Question mark on sign -->
                        <text x="100" y="89" fill="#5d4037" font-weight="900" font-size="19" text-anchor="middle" font-family="Arial">?</text>
                    </g>
                    
                    <!-- Yellow Nesting Straw Details on Nest Front -->
                    <path d="M50,135 C55,145 70,160 100,160 C130,160 145,145 150,135 C155,145 140,168 100,168 C60,168 45,145 50,135 Z" fill="#8d6e63" />
                    <path d="M55,140 Q100,170 145,140" stroke="#a1887f" stroke-width="4" stroke-linecap="round" fill="none" />
                    <path d="M62,145 Q100,175 138,145" stroke="#ffe082" stroke-width="2" stroke-dasharray="8,4" stroke-linecap="round" fill="none" />

                    <!-- Cozy leaves -->
                    <path d="M45,145 Q30,135 25,145 Q32,152 45,145 Z" fill="#81c784" />
                    <path d="M155,138 Q170,130 175,140 Q168,147 155,138 Z" fill="#81c784" />
                    
                    <!-- Little Blue Bird flying away with suitcase -->
                    <g transform="translate(130, 45) scale(0.8)">
                        <!-- Suitcase -->
                        <rect x="-8" y="15" width="12" height="10" fill="#a1887f" rx="1.5" />
                        <path d="-4,15 L-4,12 L0,12 L0,15" stroke="#5d4037" stroke-width="1.5" fill="none" />
                        <!-- Bird body -->
                        <circle cx="10" cy="5" r="14" fill="#4ea8de" />
                        <circle cx="18" cy="0" r="4" fill="#ffffff" />
                        <circle cx="18" cy="0" r="1.5" fill="#0B1D26" />
                        <polygon points="22,4 28,7 22,10" fill="#f3722c" /> <!-- Beak -->
                        <!-- Wing -->
                        <path d="M4,8 C0,5 -5,12 2,12 Z" fill="#4895ef" transform="rotate(-15)" />
                        <!-- Tail -->
                        <polygon points="-4,2 -12,-3 -10,7" fill="#4895ef" />
                    </g>
                </svg>
            <% } else if (errStatus >= 500) { %>
                <!-- 500 Sticker: Cozy House Nest with Storm Clouds, Rain and Lightning -->
                <svg class="sticker-main" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                    <!-- Sky Background circle -->
                    <circle cx="100" cy="100" r="85" fill="#f0efeb" />
                    
                    <!-- Raindrops (Animated fall) -->
                    <g class="svg-rain rain-delay-1">
                        <circle cx="65" cy="85" r="2.5" fill="#4cc9f0" />
                        <circle cx="135" cy="95" r="2.5" fill="#4cc9f0" />
                    </g>
                    <g class="svg-rain rain-delay-2">
                        <circle cx="85" cy="100" r="2.5" fill="#4cc9f0" />
                        <circle cx="115" cy="80" r="2.5" fill="#4cc9f0" />
                        <circle cx="150" cy="110" r="2.5" fill="#4cc9f0" />
                    </g>
                    
                    <!-- Dark Storm Cloud -->
                    <g class="svg-cloud">
                        <path d="M50,65 C45,65 40,60 40,55 C40,48 48,42 58,45 C65,35 80,35 88,42 C95,38 105,40 110,48 C115,42 125,45 125,52 C125,60 120,65 50,65 Z" fill="#9a8c98" />
                        <path d="M70,68 C62,68 55,62 55,55 C55,46 65,40 76,43 C84,32 102,32 112,40 C120,35 132,38 138,48 C144,42 156,46 156,54 C156,62 150,68 70,68 Z" fill="#4a4e69" opacity="0.85" />
                    </g>

                    <!-- Animated Lightning Bolt -->
                    <polygon class="svg-lightning" points="98,58 112,78 102,80 110,98 90,82 98,80" fill="#fee440" stroke="#f1c40f" stroke-width="1" />

                    <!-- Cozy House / Nest -->
                    <g>
                        <!-- Ground / Nest twig foundation -->
                        <path d="M50,150 Q100,160 150,150" stroke="#8d6e63" stroke-width="6" stroke-linecap="round" fill="none" />
                        <!-- House Body -->
                        <rect x="65" y="105" width="70" height="45" fill="#fae1dd" rx="3" stroke="#8d6e63" stroke-width="2.5" />
                        <!-- Roof (Cabin/Nest Top) -->
                        <polygon points="58,107 100,75 142,107" fill="#ffb5a7" stroke="#8d6e63" stroke-width="2.5" stroke-linejoin="round" />
                        <!-- Chimney with band-aid -->
                        <rect x="118" y="85" width="10" height="15" fill="#fcd5ce" stroke="#8d6e63" stroke-width="2" />
                        
                        <!-- Cross Band-Aid on House Wall -->
                        <g transform="translate(75, 120) rotate(15)">
                            <rect x="0" y="4" width="16" height="6" fill="#e9c46a" rx="1" />
                            <rect x="5" y="-1" width="6" height="16" fill="#e9c46a" rx="1" />
                            <circle cx="8" cy="7" r="1.5" fill="#f4a261" />
                        </g>

                        <!-- Unhappy face on the house (indicating server error) -->
                        <circle cx="93" cy="122" r="2.5" fill="#4a4e69" />
                        <circle cx="107" cy="122" r="2.5" fill="#4a4e69" />
                        <!-- Curved down sad mouth -->
                        <path d="M96,134 Q100,130 104,134" stroke="#4a4e69" stroke-width="2.5" stroke-linecap="round" fill="none" />
                        
                        <!-- Cozy Round Window -->
                        <circle cx="100" cy="95" r="7" fill="#ffffff" stroke="#8d6e63" stroke-width="1.5" />
                        <line x1="100" y1="88" x2="100" y2="102" stroke="#8d6e63" stroke-width="1" />
                        <line x1="93" y1="95" x2="107" y2="95" stroke="#8d6e63" stroke-width="1" />
                    </g>
                </svg>
            <% } else { %>
                <!-- Fallback General Error Sticker: Warning Badge with Band-Aid -->
                <svg class="sticker-main" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                    <!-- Background circle -->
                    <circle cx="100" cy="100" r="85" fill="#fff3cd" />
                    
                    <!-- Warning Triangle -->
                    <path d="M100,30 L165,145 C170,153 162,165 152,165 L48,165 C38,165 30,153 35,145 Z" fill="#ffb703" stroke="#d48c00" stroke-width="4" stroke-linejoin="round" />
                    
                    <!-- Exclamation point with eyes -->
                    <path d="M100,70 L100,115" stroke="#0B1D26" stroke-width="9" stroke-linecap="round" />
                    <circle cx="100" cy="138" r="6.5" fill="#0B1D26" />
                    
                    <!-- Small cute smiley face on warning -->
                    <circle cx="85" cy="92" r="3" fill="#ffffff" />
                    <circle cx="115" cy="92" r="3" fill="#ffffff" />
                    
                    <!-- Cozy Band-Aid slapped on warning sign -->
                    <g transform="translate(115, 125) rotate(-30)">
                        <rect x="0" y="4" width="22" height="8" fill="#e9c46a" rx="1.5" opacity="0.95" />
                        <rect x="7" y="4" width="8" height="8" fill="#f4a261" opacity="0.8" />
                    </g>
                </svg>
            <% } %>
        </div>

        <!-- Error Text -->
        <span class="error-code-badge">Status <%= errStatus %></span>
        <h1 class="error-title"><%= errorHeading %></h1>
        <p class="error-desc"><%= errMsg %></p>

        <!-- Actions -->
        <div class="error-actions">
            <a href="/" class="btn-staynest-primary">
                <i class="fas fa-home me-2"></i>Back to Homepage
            </a>
            <button onclick="history.back()" class="btn-staynest-secondary">
                <i class="fas fa-arrow-left me-2"></i>Go Back
            </button>
        </div>
    </div>
</div>